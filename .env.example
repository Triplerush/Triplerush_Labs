# ─── LLM Configuration (Chatbot RAG) ─────────────────────
# Endpoint OpenAI-compatible. Funciona con cualquier proveedor que exponga
# /v1/chat/completions estilo OpenAI (DigitalOcean Serverless Inference,
# Together, Groq, OpenRouter, OpenAI directo, Ollama local, Gemini via
# su endpoint OpenAI-compatible, etc.). Cambia de proveedor sólo tocando
# estas tres variables — el código no necesita cambios.

# API key del proveedor. Sin comillas, sin espacios.
LLM_API_KEY=your-llm-api-key-here

# Endpoint base. Default apunta a DigitalOcean Serverless Inference.
# Ejemplos para otros proveedores:
#   Together:   https://api.together.xyz/v1
#   Groq:       https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   OpenAI:     https://api.openai.com/v1
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai/
LLM_BASE_URL=https://inference.do-ai.run/v1

# Modelo a invocar. Slug exacto del proveedor.
# Defaults sugeridos por proveedor:
#   DO:         openai-gpt-oss-120b  (capable + tool calling)
#               openai-gpt-oss-20b   (más barato, RAG simple)
#   Together:   meta-llama/Llama-3.3-70B-Instruct-Turbo
#   Groq:       llama-3.3-70b-versatile
#   OpenAI:     gpt-4o-mini
#   Gemini:     gemini-2.5-flash-lite
LLM_MODEL=openai-gpt-oss-120b

# ─── Embeddings (locales, ONNX) ──────────────────────────
# fastembed corre el modelo localmente, sin llamadas externas. La primera
# vez que arranca el contenedor descarga el modelo (~80MB) y lo cachea.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Puertos ──────────────────────────────────────────────
# En producción, NPM (Nginx Proxy Manager) corre en su propio compose en el
# Droplet, escucha :80/:443 y enruta a portfolio_landing:4000 y portfolio_chatbot:8080
# por la red Docker `portfolio-net`. Los contenedores NO exponen puertos al host.
#
# En local, docker-compose.local.yml (gitignored) levanta un nginx adicional
# en :3080 que emula a NPM. Abrir http://localhost:3080 para la app integrada.
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
NGINX_PORT=3080  # Puerto del proxy local de dev (solo dev, ignorado en prod)
