# ─── LLM Configuration (Chatbot RAG) ─────────────────────
# API Key de Gemini Developer API (Google AI Studio)
# Obtener en: https://aistudio.google.com/apikey
# El tier gratuito de Gemini es suficiente para demos.
LLM_API_KEY=your-gemini-api-key-here

# Modelo de LLM a usar. Default: gemini-2.5-flash-lite (rápido y económico)
# Alternativas: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=gemini-2.5-flash-lite

# ─── Nginx Port ───────────────────────────────────────────
# Puerto del Nginx Global. Default: 80 (producción).
# En local, cambiar a 3080 (o cualquier puerto libre).
# NGINX_PORT=3080
